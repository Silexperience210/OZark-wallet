# Copy to `.env` and edit.

# host:port of your litd/tapd gRPC. Examples:
#   - litd on the same box, reachable via the LAN IP:   192.168.1.50:8443
#   - if you attach this compose to your node's docker network:   litd:8443
OZARK_GATEWAY_TAPD_HOST=127.0.0.1:8443

# Optional. After first boot, read the onion (see DEPLOY.md) and set it here to
# require the full signed URL to match, then `docker compose up -d`. Leave empty
# to use path-only auth binding (still safe; just less strict on the host part).
OZARK_GATEWAY_PUBLIC_URL=

# Optional. Operator pubkey (64-hex Nostr) allowed to call the /v1/admin/* routes
# (open/list asset channels, connect peers — these spend the node's own liquidity).
# Set it to your own wallet's Nostr pubkey. Leave empty to disable admin routes.
OZARK_GATEWAY_ADMIN_PUBKEY=

# Optional. Set to 1 during setup to allow one-tap operator claim: the wallet's
# "Devenir opérateur" button (POST /v1/admin/claim) makes the first authenticated
# caller the persisted operator — no hex to copy. Ignored once an operator exists.
# Turn it back off after claiming (anyone reaching the onion could claim while on).
OZARK_GATEWAY_ALLOW_ADMIN_CLAIM=

# Optional. Path (inside the container) to an lnd macaroon, enabling two things:
#   - Lightning-asset receive auto-credit (gateway detects invoice settlement via
#     lnd's LookupInvoice, which the tapd macaroon does not authorize) — needs
#     `invoices:read`.
#   - Sats-balance top-up (POST /v1/sats/deposit issues an lnd invoice via
#     AddInvoice) — needs `invoices:write`. Required if you enable fees below.
# Drop the file in ./secrets and point here, e.g. /secrets/lnd.macaroon. Leave
# empty to disable both. Bake a minimal macaroon with:
#   lncli bakemacaroon invoices:read invoices:write --save_to lnd.macaroon
OZARK_GATEWAY_LND_MACAROON=

# Optional. Charge users a sats fee for on-chain ops (mint/send), debited from
# their custodial sats balance and credited to the operator. Off by default (ops
# are free; the operator eats the on-chain cost). Requires an operator to exist
# and an lnd macaroon with `invoices:write` (so users can top up their sats).
#   OZARK_GATEWAY_CHARGE_FEES=1
# Markup on the estimated network fee, in basis points (10000 = 100%). 300 = 3%.
#   OZARK_GATEWAY_FEE_MARGIN_BPS=300
# Floor per chargeable op (sats), covering fixed overhead. Default 100.
#   OZARK_GATEWAY_FEE_FLOOR_SATS=100
# Assumed tx vsize (vB) for the network-fee estimate. Defaults 250 (mint) / 200.
#   OZARK_GATEWAY_MINT_VSIZE=250
#   OZARK_GATEWAY_SEND_VSIZE=200
# Fee rate (sat/vB) assumed when the request doesn't specify one. Default 5.
#   OZARK_GATEWAY_DEFAULT_FEE_RATE=5
OZARK_GATEWAY_CHARGE_FEES=

# Optional. Background maintenance interval in seconds (reconciliation + solvency
# audit + stale-invoice purge). Default 60. Set 0 to disable the loop (per-request
# reconciliation still runs).
OZARK_GATEWAY_RECONCILE_INTERVAL_SECS=

# Optional. Per-pubkey abuse protection (applied after NIP-98 signature check).
# Token bucket: BURST = max burst (bucket capacity), PER_SEC = sustained rate
# (tokens refilled per second). 429 when exceeded. Set BURST=0 to disable.
# Defaults 30 / 5. A single-use (anti-replay) check on the NIP-98 event id is
# always on and needs no config.
#   OZARK_GATEWAY_RATE_BURST=30
#   OZARK_GATEWAY_RATE_PER_SEC=5

# Optional but recommended. Encrypted ledger backups. The SQLite ledger IS the
# custody record — losing it loses everyone's balance attribution. Set DIR to
# /backups (mounted to ./backups on the host) to enable periodic snapshots, and
# KEY to a 32-byte hex secret (64 chars) to encrypt them at rest. Generate a key:
#   openssl rand -hex 32
# Leave both empty to disable. If DIR is set without KEY, snapshots are PLAINTEXT.
OZARK_GATEWAY_BACKUP_DIR=
OZARK_GATEWAY_BACKUP_KEY=
# OZARK_GATEWAY_BACKUP_INTERVAL_SECS=3600
# OZARK_GATEWAY_BACKUP_RETENTION=24
