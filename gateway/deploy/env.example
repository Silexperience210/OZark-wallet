# Copy to `.env` and edit.

# host:port of your litd/tapd gRPC. Examples:
#   - litd on the same box, reachable via the LAN IP:   192.168.1.50:8443
#   - if you attach this compose to your node's docker network:   litd:8443
OZARK_GATEWAY_TAPD_HOST=127.0.0.1:8443

# Optional. After first boot, read the onion (see DEPLOY.md) and set it here to
# require the full signed URL to match, then `docker compose up -d`. Leave empty
# to use path-only auth binding (still safe; just less strict on the host part).
OZARK_GATEWAY_PUBLIC_URL=
